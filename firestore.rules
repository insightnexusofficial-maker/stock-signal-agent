rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    match /stocks/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    match /state/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    match /snapshots/{document=**} {
      allow read: if false;
      allow write: if false;
    }
    
    match /fcm_tokens/{token} {
      // 토큰 값 자체가 문서 ID인 경우에만 본인 승인 상태를 조회할 수 있다.
      // 일반 사용자는 자기 토큰만 조회하고, 관리자만 승인 목록을 관리한다.
      allow get: if true;
      allow list: if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved'])
                    && request.resource.data.approved is bool;
      allow delete: if isAdmin();

      allow create: if request.resource.data.keys().hasOnly([
                      'token', 'nickname', 'registered_at', 'createdAt', 'approved'
                    ])
                  && request.resource.data.keys().hasAll([
                      'token', 'nickname', 'registered_at', 'createdAt', 'approved'
                    ])
                  && request.resource.data.token == token
                  && request.resource.data.token is string
                  && request.resource.data.nickname is string
                  && request.resource.data.nickname.size() <= 30
                  && request.resource.data.registered_at is string
                  && request.resource.data.createdAt is timestamp
                  && request.resource.data.approved == false;
    }
  }
}
